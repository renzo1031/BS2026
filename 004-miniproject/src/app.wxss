page {
  min-height: 100%;
  background: linear-gradient(180deg, #f7faf8 0%, #eef4f1 100%);
  color: #13231f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
button,
input,
textarea,
picker,
image,
scroll-view {
  box-sizing: border-box;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
  letter-spacing: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 8rpx 0 24rpx;
}

.page-title {
  display: block;
  color: #10231e;
  font-size: 46rpx;
  font-weight: 820;
  letter-spacing: 0;
  line-height: 1.15;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6a7772;
  font-size: 24rpx;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #20312c;
  font-size: 28rpx;
  font-weight: 760;
  letter-spacing: .5rpx;
}

.surface {
  padding: 26rpx;
  border: 1rpx solid #e1eae6;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(20, 55, 43, .05);
  transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
}

.stack > view + view,
.stack > button + button {
  margin-top: 16rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.grow {
  min-width: 0;
  flex: 1;
}

.muted {
  color: #66746e;
}

.caption {
  color: #6c7872;
  font-size: 22rpx;
}

.primary-button {
  min-height: 88rpx;
  background: #147d64;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(20, 125, 100, .16);
}

.secondary-button {
  min-height: 80rpx;
  border: 1rpx solid rgba(20, 125, 100, .18);
  background: rgba(255, 255, 255, .8);
  color: #1b6654;
}

.danger-button {
  min-height: 80rpx;
  border: 1rpx solid rgba(217, 165, 160, .8);
  background: rgba(255, 246, 245, .92);
  color: #a32d25;
}

.text-button {
  min-height: 64rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(20, 125, 100, .08);
  color: #147d64;
  line-height: 64rpx;
}

.compact-button {
  min-height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  line-height: 64rpx;
}

.field {
  margin-bottom: 24rpx;
}

.form-journey {
  display: grid;
  gap: 18rpx;
}

.form-section {
  position: relative;
  overflow: hidden;
}

.section-kicker {
  display: block;
  margin-bottom: 4rpx;
  color: #147d64;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.section-copy {
  display: block;
  margin: -6rpx 0 18rpx;
  color: #71807a;
  font-size: 23rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #25332e;
  font-size: 26rpx;
  font-weight: 600;
}

.required::after {
  content: " *";
  color: #b33b31;
}

.input,
.textarea,
.picker-field {
  width: 100%;
  min-height: 82rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(138, 159, 153, .28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .84);
  color: #12231f;
}

.textarea {
  min-height: 180rpx;
}

.field-error {
  display: block;
  margin-top: 8rpx;
  color: #a32d25;
  font-size: 24rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(20, 125, 100, .09);
  color: #15624f;
  font-size: 24rpx;
}

.status {
  flex: none;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(221, 228, 225, .82);
  color: #52605a;
  font-size: 22rpx;
}

.status--success {
  background: #e4f4ec;
  color: #126847;
}

.status--warn {
  background: #fff3d8;
  color: #8a5a00;
}

.status--danger {
  background: #fde9e7;
  color: #9d2c24;
}

.divider {
  height: 1rpx;
  margin: 20rpx 0;
  background: #e3e9e6;
}

.list-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e2e8e5;
}

.list-item:last-child {
  border-bottom: 0;
}

.safe-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.hero-panel {
  position: relative;
  overflow: hidden;
  border: 0;
  border-radius: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(17, 121, 95, .96) 0%, rgba(28, 77, 107, .94) 100%);
  box-shadow: 0 24rpx 60rpx rgba(17, 74, 61, .28);
}

.hero-panel .page-title,
.hero-panel .page-subtitle,
.hero-panel .muted,
.hero-panel .caption {
  color: rgba(255, 255, 255, .9);
}

.hero-panel .status {
  background: rgba(255, 255, 255, .18);
  color: #ffffff;
}

.hero-panel .chip,
.hero-panel .secondary-button,
.hero-panel .text-button {
  background: rgba(255, 255, 255, .16);
  color: #ffffff;
}

.hero-orbit {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-orbit::before,
.hero-orbit::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .12);
}

.hero-orbit::before {
  top: -34rpx;
  right: -12rpx;
  width: 172rpx;
  height: 172rpx;
}

.hero-orbit::after {
  bottom: -36rpx;
  left: -16rpx;
  width: 140rpx;
  height: 140rpx;
}

.motion-enter {
  animation: content-rise .34s cubic-bezier(.22, .8, .24, 1) both;
}

.motion-delay-1 { animation-delay: 40ms; }
.motion-delay-2 { animation-delay: 80ms; }
.motion-delay-3 { animation-delay: 120ms; }
.motion-delay-4 { animation-delay: 160ms; }

.motion-press {
  transition: transform .2s ease, opacity .2s ease;
}

.motion-press:active {
  transform: scale(.98);
  opacity: .88;
}

@keyframes content-rise {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  .motion-enter,
  .motion-press,
  .surface {
    animation: none;
    transition: none;
  }
}
