.messages-page {
  padding-top: 0;
}

.message-intro {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 4rpx 26rpx;
}

.message-title,
.message-subtitle,
.unread-value,
.unread-label {
  display: block;
}

.message-title {
  color: #1a2a24;
  font-size: 34rpx;
  font-weight: 760;
}

.message-subtitle {
  margin-top: 8rpx;
  color: #73817b;
  font-size: 23rpx;
}

.unread-bubble {
  min-width: 96rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid #cfe5dc;
  border-radius: 18rpx;
  background: #e1f1eb;
  text-align: center;
}

.unread-value {
  color: #12684f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.unread-label {
  margin-top: 4rpx;
  color: #4d7e6d;
  font-size: 20rpx;
}

.segment {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rpx;
  margin-bottom: 24rpx;
  padding: 4rpx;
  border: 1rpx solid #dfe9e5;
  border-radius: 18rpx;
  background: #eaf1ee;
}

.segment-item {
  min-height: 66rpx;
  margin: 0;
  background: transparent;
  color: #64716b;
  font-size: 25rpx;
  line-height: 66rpx;
}

.segment-item--active {
  background: #ffffff;
  color: #145b4a;
  font-weight: 700;
  box-shadow: 0 3rpx 10rpx rgba(20, 60, 49, .06);
}

.section-note {
  margin: 0 4rpx 16rpx;
  color: #2c3a35;
  font-size: 26rpx;
}

.conversation-list,
.notification-groups {
  display: grid;
  gap: 12rpx;
}

.conversation-card,
.notification-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e1e9e5;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 63, 52, .035);
}

.conversation-mark {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 18rpx;
  background: #dff0e9;
  color: #147d64;
  font-size: 30rpx;
  font-weight: 750;
}

.item-title {
  min-width: 0;
  overflow: hidden;
  color: #25332e;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conversation-time {
  display: block;
  margin-top: 8rpx;
}

.notification-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 4rpx 14rpx;
}

.notification-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 15rpx;
  flex: none;
  border-radius: 50%;
  background: transparent;
}

.notification--unread .notification-dot {
  background: #d94a3e;
}

.notification-content {
  display: block;
  margin-top: 6rpx;
  line-height: 1.45;
}

.group-block {
  display: grid;
  gap: 12rpx;
}

.group-title {
  display: block;
  color: #26342f;
  font-size: 27rpx;
  font-weight: 700;
}

.notification-tag {
  flex: none;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #eef5f2;
  color: #176953;
  font-size: 20rpx;
}

.notification--unread {
  border-color: #cfe5dc;
}

@media (max-width: 420px) {
  .message-title {
    font-size: 32rpx;
  }

  .segment-item {
    font-size: 24rpx;
  }
}
