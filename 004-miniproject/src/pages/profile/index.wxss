.profile-page { padding-top: 0; }
.profile-hero { display: flex; align-items: center; gap: 20rpx; padding: 30rpx 24rpx; }
.avatar { width: 112rpx; height: 112rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 28rpx; background: rgba(255,255,255,.18); color: #fff; font-size: 44rpx; font-weight: 800; }
.avatar-image { width: 100%; height: 100%; border-radius: inherit; }
.profile-title-row { gap: 12rpx; flex-wrap: wrap; }
.nickname { display: block; color: #16251f; font-size: 38rpx; font-weight: 750; }
.profile-meta, .verification { display: block; margin-top: 5rpx; color: #68756f; font-size: 23rpx; }
.verification { color: #147d64; }
.profile-hero .nickname { color: #fff; }
.profile-hero .profile-meta,
.profile-hero .verification { color: rgba(255,255,255,.82); }
.profile-hero .text-button { background: rgba(255,255,255,.18); color: #fff; }
.completion-card { margin-top: 20rpx; }
.completion-title, .completion-desc, .completion-value { display: block; }
.completion-title { color: #24332d; font-size: 28rpx; font-weight: 700; }
.completion-desc { margin-top: 4rpx; color: #6d7a74; font-size: 22rpx; }
.completion-value { color: #147d64; font-size: 40rpx; font-weight: 800; }
.interest-tags { margin-top: 18rpx; }
.interest-empty { display: block; margin-top: 18rpx; }
.stats { display: grid; grid-template-columns: repeat(4, 1fr); margin: 24rpx -26rpx -26rpx; padding: 20rpx 10rpx 22rpx; border-top: 1rpx solid #e4ece8; text-align: center; }
.stats view + view { border-left: 1rpx solid #e0e7e4; }
.stat-value, .stat-label { display: block; }
.stat-value { color: #163d33; font-size: 34rpx; font-weight: 750; }
.stat-label { margin-top: 5rpx; color: #75817c; font-size: 20rpx; }
.quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.quick-card { display: flex; min-height: 148rpx; align-items: flex-start; gap: 16rpx; padding: 22rpx; }
.quick-icon { width: 46rpx; height: 46rpx; flex: none; }
.quick-title, .quick-desc { display: block; }
.quick-title { color: #26342f; font-size: 27rpx; font-weight: 700; }
.quick-desc { margin-top: 5rpx; color: #72807a; font-size: 21rpx; line-height: 1.35; }
.menu { padding-top: 0; padding-bottom: 0; }
.menu-item { min-height: 94rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 1rpx solid #e2e8e5; color: #2a3833; }
.menu-item:last-child { border-bottom: 0; }
.menu-arrow { color: #87918d; font-size: 42rpx; font-weight: 300; }
.logout { margin-top: 30rpx; }

@media (max-width: 420px) {
  .stats { grid-template-columns: repeat(2, 1fr); gap: 1rpx; }
  .stats view { padding: 14rpx 0; }
  .stats view + view { border-left: 0; }
  .quick-grid { grid-template-columns: 1fr; }
}
