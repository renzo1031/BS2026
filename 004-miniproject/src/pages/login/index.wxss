page {
  background: linear-gradient(155deg, #edf5f1 0%, #f7f9f8 58%, #eef4f1 100%);
}

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 0;
}

.login-main {
  min-height: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 52rpx 10rpx 64rpx;
}

.brand-mark {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #147d64;
  box-shadow: 0 16rpx 34rpx rgba(20, 125, 100, .2);
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 800;
}

.login-title,
.login-subtitle,
.trust-note,
.login-tip {
  display: block;
}

.login-title {
  max-width: 600rpx;
  margin-top: 42rpx;
  color: #132720;
  font-size: 52rpx;
  font-weight: 820;
  line-height: 1.22;
}

.login-subtitle {
  max-width: 560rpx;
  margin-top: 18rpx;
  color: #64736d;
  font-size: 27rpx;
  line-height: 1.65;
}

.trust-note {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 30rpx;
  color: #38675a;
  font-size: 23rpx;
}

.trust-line {
  width: 40rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #147d64;
}

.login-panel {
  padding: 30rpx 4rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(102, 128, 117, .16);
}

.privacy-row {
  margin-bottom: 26rpx;
}

.privacy-label {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: #50615a;
  font-size: 23rpx;
  line-height: 1.65;
}

.privacy-label checkbox {
  flex: none;
  transform: scale(.82);
  transform-origin: top left;
}

.login-tip {
  margin-top: 20rpx;
  color: #74817c;
  font-size: 22rpx;
  line-height: 1.55;
  text-align: center;
}
