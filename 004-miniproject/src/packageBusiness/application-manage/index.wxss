page {
  background: #f3f6f4;
}

.application-manage-page {
  padding-top: 22rpx;
}

.manage-head {
  padding: 0 4rpx 18rpx;
}

.manage-eyebrow {
  display: block;
  color: #147d64;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.manage-title-row,
.applicant-head,
.list-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  display: -webkit-box;
  min-width: 0;
  overflow: hidden;
  color: #1b3026;
  font-size: 35rpx;
  font-weight: 820;
  line-height: 1.25;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.manage-title-row .status {
  margin-top: 6rpx;
}

.manage-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 24rpx;
  margin-top: 12rpx;
}

.status-pair {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.status-label {
  color: #89968f;
  font-size: 21rpx;
}

.status-value {
  color: #52655b;
  font-size: 22rpx;
  font-weight: 650;
}

.manage-stats {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rpx;
  overflow: hidden;
  border: 1rpx solid #dce8e2;
  border-radius: 16rpx;
  background: #dce8e2;
}

.manage-stat {
  min-width: 0;
  padding: 16rpx 8rpx;
  background: #ffffff;
  text-align: center;
}

.manage-value,
.manage-label {
  display: block;
}

.manage-value {
  color: #18735c;
  font-size: 29rpx;
  font-weight: 780;
}

.manage-label {
  margin-top: 4rpx;
  color: #7c8b84;
  font-size: 20rpx;
}

.lifecycle-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 18rpx 0 24rpx;
}

.compact {
  min-height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  font-size: 23rpx;
  line-height: 64rpx;
}

.applications-section {
  padding-top: 2rpx;
}

.list-heading {
  align-items: baseline;
  margin-bottom: 13rpx;
}

.section-title {
  display: block;
  margin-bottom: 0;
  color: #21372c;
  font-size: 29rpx;
}

.section-copy {
  display: block;
  margin-top: 4rpx;
  color: #839088;
  font-size: 21rpx;
}

.list-count {
  flex: none;
  color: #89958f;
  font-size: 21rpx;
}

.list-stack {
  display: grid;
  gap: 12rpx;
}

.application-card {
  padding: 20rpx 22rpx;
  border: 1rpx solid #e0e9e5;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(34, 63, 52, .035);
}

.applicant {
  display: block;
  color: #253c31;
  font-size: 28rpx;
  font-weight: 720;
}

.caption {
  display: block;
  margin-top: 4rpx;
}

.answers {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f3f8f5;
}

.answers-title {
  display: block;
  margin-bottom: 5rpx;
  color: #3c5b4d;
  font-size: 22rpx;
  font-weight: 700;
}

.answer,
.message {
  display: block;
  margin-top: 7rpx;
  color: #52655b;
  font-size: 23rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-label {
  margin-right: 8rpx;
  color: #7f8d86;
}

.decision-row {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 18rpx;
}

@media (max-width: 420px) {
  .manage-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .activity-title {
    font-size: 32rpx;
  }
}
