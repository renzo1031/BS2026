page {
  background: #f3f6f4;
}

.editor-page {
  padding-top: 22rpx;
}

.editor-head {
  padding: 0 4rpx 22rpx;
}

.editor-eyebrow {
  display: block;
  color: #147d64;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.editor-title {
  display: block;
  margin-top: 7rpx;
  color: #182b23;
  font-size: 40rpx;
  font-weight: 820;
  line-height: 1.2;
}

.editor-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #74827b;
  font-size: 23rpx;
  line-height: 1.55;
}

.template-card,
.checklist-card {
  margin-bottom: 16rpx;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-note {
  flex: none;
  color: #81938a;
  font-size: 21rpx;
}

.check-mark {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #dff1e9;
  color: #147d64;
  font-size: 26rpx;
  font-weight: 800;
}

.template-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.template-chip {
  min-height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #d3e7de;
  border-radius: 999rpx;
  background: #edf7f2;
  color: #16654f;
  font-size: 23rpx;
  line-height: 60rpx;
}

.check-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 7rpx 0;
  color: #53665c;
  font-size: 24rpx;
  line-height: 1.5;
}

.check-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  flex: none;
  border-radius: 50%;
  background: #147d64;
}

.form-journey {
  display: grid;
  gap: 16rpx;
}

.form-section {
  border-radius: 16rpx;
}

.short {
  min-height: 130rpx;
}

.picker-row {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 12rpx;
}

.last-field {
  margin-bottom: 0;
}

.counter {
  display: block;
  margin-top: 7rpx;
  text-align: right;
}

.upload-button {
  width: 250rpx;
  margin: 0;
}

.image-tip {
  display: block;
  margin-top: 10rpx;
  line-height: 1.5;
}

.editor-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin: 22rpx -4rpx 0;
  padding: 0 4rpx calc(20rpx + env(safe-area-inset-bottom));
}

.editor-actions button {
  width: 100%;
  margin: 0;
}

@media (max-width: 420px) {
  .editor-title {
    font-size: 36rpx;
  }

  .picker-row {
    grid-template-columns: 1fr;
  }
}
