page {
  background: #f3f6f4;
}

.favorites-page {
  max-width: 760rpx;
  margin: 0 auto;
}

.segment {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  margin-bottom: 28rpx;
  padding: 6rpx;
  border: 1rpx solid #dfe8e4;
  border-radius: 18rpx;
  background: #e8eeeb;
}

.segment-item {
  min-width: 0;
  min-height: 66rpx;
  margin: 0;
  padding: 0 6rpx;
  border-radius: 16rpx;
  background: transparent;
  color: #64736d;
  font-size: 23rpx;
  line-height: 66rpx;
}

.segment-item--active {
  background: #ffffff;
  box-shadow: 0 5rpx 14rpx rgba(34, 63, 52, .07);
  color: #12684f;
  font-weight: 700;
}

.list-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  padding: 4rpx 4rpx 18rpx;
}

.list-heading .section-title,
.evaluate-heading .section-title {
  margin-bottom: 0;
  font-size: 31rpx;
}

.section-copy {
  margin: 6rpx 0 0;
}

.item-count {
  flex: none;
  color: #147d64;
  font-size: 23rpx;
  font-weight: 700;
}

.favorite-list,
.review-list,
.target-list {
  display: grid;
  gap: 14rpx;
}

.favorite-card,
.review-card,
.target-card,
.reputation-overview,
.distribution-list,
.evaluation-search,
.evaluation-form {
  border: 1rpx solid #e0e9e5;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(34, 63, 52, .045);
}

.favorite-card {
  padding: 22rpx;
}

.favorite-top,
.favorite-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.scene-name {
  min-width: 0;
  overflow: hidden;
  color: #147d64;
  font-size: 23rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-title,
.favorite-time,
.list-end,
.score,
.score-label,
.received-value,
.received-label,
.reputation-note,
.review-rating,
.review-time,
.review-activity,
.form-title,
.target-name,
.target-id {
  display: block;
}

.favorite-title {
  margin-top: 14rpx;
  color: #1e2e28;
  font-size: 30rpx;
  font-weight: 750;
  line-height: 1.4;
}

.favorite-time {
  margin-top: 10rpx;
  color: #718079;
  font-size: 22rpx;
}

.favorite-footer {
  justify-content: flex-end;
  margin-top: 18rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #edf1ef;
}

.remove-button {
  color: #983a32;
}

.load-more {
  margin-top: 22rpx;
}

.list-end {
  padding: 24rpx 0 4rpx;
  color: #829089;
  font-size: 22rpx;
  text-align: center;
}

.reputation-flow,
.evaluation-content {
  display: grid;
  gap: 28rpx;
}

.reputation-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 28rpx;
}

.score-block,
.received-block {
  min-width: 0;
}

.received-block {
  padding-left: 28rpx;
  border-left: 1rpx solid #e5ece8;
}

.score,
.received-value {
  color: #153f33;
  font-size: 58rpx;
  font-weight: 820;
  line-height: 1.1;
}

.received-value {
  color: #147d64;
}

.score-label,
.received-label {
  margin-top: 8rpx;
  color: #53645d;
  font-size: 23rpx;
  font-weight: 650;
}

.reputation-note {
  grid-column: 1 / -1;
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e8eeeb;
  color: #74817b;
  font-size: 22rpx;
}

.distribution-section .section-title,
.recent-section .section-title,
.target-section .section-title {
  margin-left: 4rpx;
}

.distribution-list {
  padding: 4rpx 24rpx;
}

.distribution-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  border-bottom: 1rpx solid #e8eeeb;
  color: #4e5f58;
  font-size: 24rpx;
}

.distribution-row:last-child {
  border-bottom: 0;
}

.distribution-count {
  color: #153f33;
  font-weight: 700;
}

.review-card {
  padding: 22rpx;
}

.review-rating {
  color: #153f33;
  font-size: 28rpx;
  font-weight: 750;
}

.review-time,
.review-activity,
.target-id {
  color: #74817b;
  font-size: 21rpx;
}

.review-tags {
  margin-top: 16rpx;
}

.review-activity {
  margin-top: 14rpx;
}

.evaluate-heading {
  padding: 4rpx 4rpx 18rpx;
}

.evaluation-search {
  padding: 22rpx;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
}

.search-row .secondary-button {
  white-space: nowrap;
}

.evaluation-form {
  padding: 24rpx;
}

.form-title {
  margin-bottom: 22rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #e8eeeb;
  color: #1f312a;
  font-size: 29rpx;
  font-weight: 750;
}

.evaluation-form .last-field {
  margin-bottom: 0;
}

.note-input {
  min-height: 132rpx;
}

.target-card {
  display: flex;
  min-height: 104rpx;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 22rpx;
}

.target-name {
  color: #26372f;
  font-size: 27rpx;
  font-weight: 700;
}

.target-id {
  margin-top: 5rpx;
}

.evaluate-button {
  width: auto;
  min-width: 164rpx;
  flex: none;
}

@media (max-width: 420px) {
  .search-row {
    grid-template-columns: 1fr;
  }

  .search-row .secondary-button {
    width: 100%;
  }
}
