.profile-edit-page {
  padding-top: 28rpx;
}

.profile-card {
  padding-bottom: 20rpx;
}

.profile-preview {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar-picker {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex: none;
  overflow: hidden;
  border-radius: 20rpx;
  background: #dfeee8;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  background: #dfeee8;
  color: #12644f;
  font-size: 38rpx;
  font-weight: 750;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-edit-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  display: flex;
  width: 28rpx;
  height: 28rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, .9);
}

.avatar-edit-badge image {
  width: 18rpx;
  height: 18rpx;
}

.avatar-loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(16, 35, 30, .55);
  color: #ffffff;
  font-size: 19rpx;
}

.preview-name {
  display: block;
  overflow: hidden;
  color: #22322c;
  font-size: 30rpx;
  font-weight: 720;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-note,
.preview-empty {
  display: block;
  margin-top: 8rpx;
}

.avatar-refresh {
  display: inline-block;
  width: auto;
  min-height: 72rpx;
  margin: 0 -12rpx;
  padding: 18rpx 12rpx;
  border: 0;
  background: transparent;
  color: #147d64;
  font-size: 21rpx;
  line-height: 36rpx;
  text-align: left;
}

.preview-tags {
  margin-top: 16rpx;
}

.form-section .section-title {
  margin-bottom: 20rpx;
}

.two-columns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.last-field {
  margin-bottom: 0;
}

.tags-input {
  min-height: 130rpx;
}

.counter {
  display: block;
  margin-top: 6rpx;
  text-align: right;
}

@media (max-width: 420px) {
  .two-columns {
    grid-template-columns: 1fr;
  }
}
