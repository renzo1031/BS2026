<view class="page safety-page">
  <view class="page-header motion-enter">
    <text class="page-title">安全中心</text>
    <text class="page-subtitle">举报、申诉和黑名单都在这里处理。</text>
  </view>

  <view class="segment segment--three motion-enter motion-delay-1" role="tablist">
    <button class="segment-item motion-press {{tab === 'submit' ? 'segment-item--active' : ''}}" data-tab="submit" bindtap="switchTab" role="tab" aria-selected="{{tab === 'submit'}}">提交举报</button>
    <button class="segment-item motion-press {{tab === 'cases' ? 'segment-item--active' : ''}}" data-tab="cases" bindtap="switchTab" role="tab" aria-selected="{{tab === 'cases'}}">案件与申诉</button>
    <button class="segment-item motion-press {{tab === 'blocks' ? 'segment-item--active' : ''}}" data-tab="blocks" bindtap="switchTab" role="tab" aria-selected="{{tab === 'blocks'}}">黑名单</button>
  </view>

  <page-state wx:if="{{state !== 'ready'}}" state="{{state}}" title="加载安全中心" message="请下拉或点击重试" bind:action="load" />

  <block wx:elif="{{tab === 'submit'}}">
    <view wx:if="{{!canSubmit}}" class="notice notice--warn motion-enter motion-delay-2">当前账号未完成认证或状态受限，只能查看案件和提交符合条件的申诉。</view>
    <view class="section-intro motion-enter motion-delay-2">
      <text class="section-title">说明需要处理的问题</text>
      <text class="section-copy">请填写可核实的事实，不要提交无关隐私。</text>
    </view>
    <view class="surface report-form motion-enter motion-delay-3">
      <view class="field target-field">
        <text class="field-label required">举报对象</text>
        <view class="target-row">
          <picker class="target-picker" range="{{targetTypeLabels}}" value="{{targetTypeIndex}}" bindchange="onTargetTypeChange"><view class="picker-field">{{targetTypeLabels[targetTypeIndex]}}</view></picker>
          <input class="input target-input" type="number" value="{{targetId}}" data-field="targetId" bindinput="onInput" placeholder="对象 ID" aria-label="举报对象 ID" />
        </view>
      </view>
      <view class="field">
        <text class="field-label required">举报原因</text>
        <picker range="{{reasonLabels}}" value="{{reasonIndex}}" bindchange="onReasonChange"><view class="picker-field">{{reasonLabels[reasonIndex]}}</view></picker>
      </view>
      <view class="field last-field">
        <text class="field-label">事实说明</text>
        <textarea class="textarea" maxlength="1000" value="{{description}}" data-field="description" bindinput="onInput" placeholder="描述发生了什么，避免填写无关个人隐私" />
        <text class="caption counter">{{description.length}} / 1000</text>
      </view>
      <button class="primary-button submit-button motion-press" loading="{{submitting}}" disabled="{{submitting || !canSubmit}}" bindtap="submitReport">提交举报</button>
    </view>
  </block>

  <block wx:elif="{{tab === 'cases'}}">
    <view class="case-segment motion-enter motion-delay-2" role="tablist">
      <button class="case-tab motion-press {{caseKind === 'mine' ? 'case-tab--active' : ''}}" data-kind="mine" bindtap="switchCaseKind" role="tab" aria-selected="{{caseKind === 'mine'}}">我的举报 {{mineTotal}}</button>
      <button class="case-tab motion-press {{caseKind === 'affected' ? 'case-tab--active' : ''}}" data-kind="affected" bindtap="switchCaseKind" role="tab" aria-selected="{{caseKind === 'affected'}}">影响我的案件 {{affectedTotal}}</button>
    </view>

    <block wx:if="{{caseKind === 'mine'}}">
      <page-state wx:if="{{!mine.length}}" state="empty" title="暂无举报记录" message="提交的举报会在这里显示处理状态" />
      <view wx:else class="case-list">
        <view wx:for="{{mine}}" wx:key="id" class="surface case-card motion-enter motion-delay-2">
          <view class="row-between"><text class="case-target" data-type="{{item.targetType}}" data-id="{{item.targetId}}" bindtap="openTarget">{{item.targetText}}</text><text class="status">{{item.statusText}}</text></view>
          <view class="case-meta"><text>{{item.reasonText}}</text><text>{{item.createdAtText}}</text></view>
          <text wx:if="{{item.description}}" class="case-copy">{{item.description}}</text>
          <text wx:if="{{item.resolution}}" class="resolution">处理结论：{{item.resolution}}</text>
        </view>
      </view>
      <button wx:if="{{mineHasMore}}" class="secondary-button load-more motion-press" loading="{{loadingCases}}" disabled="{{loadingCases}}" bindtap="loadMoreCases">加载更多</button>
    </block>

    <block wx:else>
      <page-state wx:if="{{!affected.length}}" state="empty" title="没有影响你的处置" message="仅已处置、申诉或复核完成的案件会显示" />
      <view wx:else class="case-list">
        <view wx:for="{{affected}}" wx:key="id" class="surface case-card motion-enter motion-delay-2">
          <view class="row-between"><text class="case-target" data-type="{{item.targetType}}" data-id="{{item.targetId}}" bindtap="openTarget">{{item.targetText}}</text><text class="status {{item.status === 'REVOKED' ? 'status--success' : 'status--warn'}}">{{item.statusText}}</text></view>
          <view class="case-meta"><text>案件记录</text><text>{{item.createdAtText}}</text></view>
          <text wx:if="{{item.resolution}}" class="resolution">处置结论：{{item.resolution}}</text>
          <text wx:if="{{item.appealReason}}" class="case-copy">申诉理由：{{item.appealReason}}</text>
          <text wx:if="{{item.appealResolution}}" class="resolution">复核结论：{{item.appealResolution}}</text>
          <button wx:if="{{item.status === 'ACTIONED' && appealId !== item.id}}" class="secondary-button appeal-button motion-press" data-id="{{item.id}}" bindtap="startAppeal">对此处置申诉</button>
          <view wx:if="{{appealId === item.id}}" class="appeal-form">
            <textarea class="textarea appeal-input" maxlength="1000" value="{{appealReason}}" data-field="appealReason" bindinput="onInput" placeholder="说明事实和希望复核的原因（至少 2 字）" />
            <view class="appeal-actions"><button class="text-button compact-button motion-press" bindtap="cancelAppeal">取消</button><button class="primary-button compact-button motion-press" loading="{{appealing}}" disabled="{{appealing}}" bindtap="submitAppeal">提交申诉</button></view>
          </view>
        </view>
      </view>
      <button wx:if="{{affectedHasMore}}" class="secondary-button load-more motion-press" loading="{{loadingCases}}" disabled="{{loadingCases}}" bindtap="loadMoreCases">加载更多</button>
    </block>
  </block>

  <block wx:else>
    <view class="section-intro motion-enter motion-delay-2">
      <text class="section-title">屏蔽不想互动的用户</text>
      <text class="section-copy">从申请或会话成员信息中取得用户 ID。</text>
    </view>
    <view class="surface block-form motion-enter motion-delay-3">
      <text class="field-label required">用户 ID</text>
      <view class="block-row">
        <input class="input" type="number" value="{{blockId}}" data-field="blockId" bindinput="onInput" placeholder="请输入用户 ID" aria-label="要屏蔽的用户 ID" />
        <button class="secondary-button compact-button motion-press" loading="{{blockBusy}}" disabled="{{blockBusy || !canSubmit}}" bindtap="addBlock">加入黑名单</button>
      </view>
    </view>
    <view class="section block-section motion-enter motion-delay-4">
      <text class="section-title">当前黑名单</text>
      <page-state wx:if="{{!blocks.length}}" state="empty" title="黑名单为空" message="你尚未拉黑同校用户" />
      <view wx:else class="surface block-list">
        <view wx:for="{{blocks}}" wx:key="id" class="list-item block-item">
          <view class="grow"><text class="block-name">{{item.nickname}}</text><text class="caption">用户 #{{item.id}}</text></view>
          <button class="text-button compact-button unblock-button motion-press" data-id="{{item.id}}" bindtap="removeBlock">移出</button>
        </view>
      </view>
    </view>
  </block>
</view>
