page {
  background: #f3f6f4;
}

.safety-page {
  max-width: 760rpx;
  margin: 0 auto;
}

.segment,
.case-segment {
  display: grid;
  gap: 6rpx;
  padding: 6rpx;
  border: 1rpx solid #dfe8e4;
  border-radius: 18rpx;
  background: #e8eeeb;
}

.segment {
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 28rpx;
}

.case-segment {
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.segment-item,
.case-tab {
  min-width: 0;
  min-height: 66rpx;
  margin: 0;
  padding: 0 6rpx;
  border-radius: 16rpx;
  background: transparent;
  color: #64736d;
  font-size: 23rpx;
  line-height: 66rpx;
}

.segment-item--active,
.case-tab--active {
  background: #ffffff;
  box-shadow: 0 5rpx 14rpx rgba(34, 63, 52, .07);
  color: #12684f;
  font-weight: 700;
}

.section-intro {
  margin: 4rpx 4rpx 18rpx;
}

.section-intro .section-title {
  margin-bottom: 0;
  font-size: 30rpx;
}

.section-copy {
  display: block;
  margin-top: 7rpx;
  color: #738079;
  font-size: 22rpx;
}

.notice {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  font-size: 23rpx;
  line-height: 1.55;
}

.notice--warn {
  background: #fff3dc;
  color: #765015;
}

.report-form,
.block-form,
.case-card,
.block-list {
  border: 1rpx solid #e0e9e5;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(34, 63, 52, .045);
}

.report-form,
.block-form {
  padding: 24rpx;
}

.report-form .field {
  margin-bottom: 24rpx;
}

.report-form .last-field {
  margin-bottom: 0;
}

.target-row,
.block-row {
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr);
  gap: 12rpx;
}

.target-picker,
.target-input,
.block-row .input {
  min-width: 0;
}

.counter {
  display: block;
  margin-top: 6rpx;
  text-align: right;
}

.submit-button {
  margin-top: 26rpx;
}

.case-list {
  display: grid;
  gap: 14rpx;
}

.case-card {
  padding: 22rpx;
}

.case-target,
.case-meta,
.case-copy,
.resolution,
.block-name {
  display: block;
}

.case-target {
  color: #145b4a;
  font-size: 27rpx;
  font-weight: 750;
}

.case-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #7a8781;
  font-size: 21rpx;
}

.case-copy {
  margin-top: 14rpx;
  color: #4d5b55;
  font-size: 23rpx;
  line-height: 1.6;
}

.resolution {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f0f5f2;
  color: #254c40;
  font-size: 23rpx;
  line-height: 1.55;
}

.appeal-button {
  margin-top: 18rpx;
}

.appeal-form {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e1e8e5;
}

.appeal-input {
  min-height: 150rpx;
}

.appeal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 12rpx;
}

.appeal-actions button {
  width: auto;
  margin: 0;
}

.load-more {
  margin-top: 20rpx;
}

.block-row {
  grid-template-columns: minmax(0, 1fr) auto;
  margin-top: 2rpx;
}

.block-row button {
  white-space: nowrap;
}

.block-section {
  margin-top: 30rpx;
}

.block-section .section-title {
  margin-left: 4rpx;
}

.block-list {
  padding-top: 4rpx;
  padding-bottom: 4rpx;
}

.block-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
}

.block-item + .block-item {
  border-top: 1rpx solid #e8eeeb;
}

.block-name {
  color: #283630;
  font-size: 26rpx;
  font-weight: 700;
}

.block-item .caption {
  display: block;
  margin-top: 5rpx;
}

.unblock-button {
  flex: none;
  color: #983a32;
}

@media (max-width: 420px) {
  .target-row {
    grid-template-columns: 1fr;
  }

  .block-row {
    grid-template-columns: 1fr;
  }

  .block-row button {
    width: 100%;
  }
}
